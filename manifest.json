{
  "name": "Popup Test",
  "version": "0.1",
  "manifest_version": 3,
  "description": "A test browser extension.",
  "icons": {
      "16": "assets/icon.jpg"
  },
  "action": {
      "default_popup": "popup/popup.html",
      "default_icon": "assets/icon.jpg"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.ts"],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  }
}