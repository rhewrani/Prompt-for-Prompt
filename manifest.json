{
  "name": "Prompt for Prompt - Prompt Optimizer",
  "version": "1.0",
  "manifest_version": 3,
  "description": "A browser extension that optimizes prompts for LLMs.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "icons": {
      "16": "assets/icon_16.png",
      "32": "assets/icon_32.png",
      "48": "assets/icon_48.png",
      "128": "assets/icon_128.png"
  },
  "action": {
      "default_popup": "popup/popup.html",
      "default_icon": "assets/icon_16.png"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.ts"],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  }
}